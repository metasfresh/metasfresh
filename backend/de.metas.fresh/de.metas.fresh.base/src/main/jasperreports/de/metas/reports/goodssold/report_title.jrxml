	<queryString>
		<![CDATA[SELECT *
FROM report.goods_sales_report(
        p_date_from =>  $P{DateFrom}::date,
        p_date_to =>  $P{DateTo}::date,
        p_bpartner_id => $P{C_BPartner_ID}, 
        p_bpartner_group_id =>  $P{C_BP_Group_ID},
        p_product_id =>  $P{M_Product_ID}
     )
     limit 1
;]]>
	</queryString>
