	<queryString>
		<![CDATA[SELECT report_level,             -- 'SUMMARY' | 'DETAIL'

       -- -------------------------------------------------------
       -- Mandatory dimensions (both levels)
       -- -------------------------------------------------------
       c_acctschema_id,
       ad_org_id,
       organization,
       account_id,
       account_value,
       account_name,
       c_bpartner_id,
       partnerValue,
       partnerName,
       main_currency_id,
       main_currency,
       c_currency_id,
       currency,

       -- -------------------------------------------------------
       -- Summary-level amounts
       -- -------------------------------------------------------
       oi_open_amt,              -- SUM(OI_OpenAmount) of surviving keys
       oi_open_amt_unreconciled, -- SUM where IsOpenItemsReconciled='N'
       oldest_open_dateacct,

       -- -------------------------------------------------------
       -- Data-quality flags (summary level)
       -- -------------------------------------------------------
       has_open_items,           -- 'Y' if gl_open_balance_amt > tolerance

       -- -------------------------------------------------------
       -- Detail-level columns (populated only when p_show_details='Y')
       -- -------------------------------------------------------
       fact_acct_id,
       dateacct,
       documentno,
       oi_trxtype,
       openitemkey,
       isopenitemsreconciled,
       amt_acct_dr,
       amt_acct_cr,
       amt_source_dr,
       amt_source_cr,
       description,
       oi_openamount,

       -- -------------------------------------------------------
       -- Diagnostics
       -- -------------------------------------------------------
       total_fact_lines,
       open_fact_lines,
       
       -- -------------------------------------------------------
       -- Parameters
       -- -------------------------------------------------------
           param_acct_schema,
           param_account,
           param_bpartner

FROM report.open_account_balance_report(
        p_date => $P{Date},
        p_c_acctschema_id => $P{C_AcctSchema_ID},
	    p_ad_org_id => $P{AD_Org_ID}, 
	    p_account_id => $P{Account_ID},
	    p_c_bpartner_id => $P{C_BPartner_ID}, 
        p_tolerance => $P{Tolerance},
        p_showdetails => $P{showdetails}
  );]]>
	</queryString>
