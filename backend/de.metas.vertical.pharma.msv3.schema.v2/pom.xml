<project
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd"
	xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<artifactId>de.metas.parent</artifactId>
		<groupId>de.metas</groupId>
		<version>10.0.0</version>
	</parent>

	<groupId>de.metas.vertical.pharma</groupId>
	<artifactId>metasfresh-pharma.msv3.schema.v2</artifactId>
	<version>10.0.0</version>
	<packaging>jar</packaging>

	<profiles>
		<profile>
			<!--
			    Regenerate JAXB sources from WSDL schemas in src/main/resources/**/*.wsdl.
			    Run this profile whenever a schema file changes:
			      mvn generate-sources -Pregenerate-jaxb-sources
			    Or regenerate all JAXB modules at once:
			      ./misc/dev-support/scripts/regenerate-jaxb-sources.sh
			    After regeneration, commit the changed java-xjc files together with the schema change.
			-->
			<id>regenerate-jaxb-sources</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.jvnet.jaxb2.maven2</groupId>
						<artifactId>maven-jaxb2-plugin</artifactId>
						<executions>
							<execution>
								<id>v2</id>
								<phase>generate-sources</phase>
								<goals>
									<goal>generate</goal>
								</goals>
								<configuration>
									<generatePackage>de.metas.vertical.pharma.vendor.gateway.msv3.schema.v2</generatePackage>
									<schemaIncludes>*.wsdl</schemaIncludes>
									<schemaDirectory>${project.basedir}/src/main/resources/de/metas/vertical/pharma/vendor/gateway/msv3/schema/v2</schemaDirectory>
									<generateDirectory>${project.basedir}/src/main/java-xjc</generateDirectory>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>
