<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<parent>
		<groupId>de.metas.payment.sepa</groupId>
		<artifactId>de.metas.payment.sepa</artifactId>
		<version>10.0.0</version>
		<relativePath>../pom.xml</relativePath>
	</parent>

	<modelVersion>4.0.0</modelVersion>
	<artifactId>de.metas.payment.sepa.schema.pain_008_003_02</artifactId>
	<packaging>jar</packaging>

	<description>SEPA Payments - schema - pain_008_003_02 (Direct Debit)</description>

	<build>
		<plugins>
			<!-- Adds src/main/java-xjc as a compile source root without regenerating.
			     To regenerate after an XSD change: mvn generate-sources -Pregenerate-jaxb-sources
			     Or: ./misc/dev-support/scripts/regenerate-jaxb-sources.sh -->
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>build-helper-maven-plugin</artifactId>
				<version>3.3.0</version>
				<executions>
					<execution>
						<id>add-jaxb-sources</id>
						<phase>generate-sources</phase>
						<goals>
							<goal>add-source</goal>
						</goals>
						<configuration>
							<sources>
								<source>src/main/java-xjc</source>
							</sources>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

	<profiles>
		<profile>
			<!--
			    Regenerate JAXB sources from XSD schemas in src/main/xsd/.
			    Run this profile whenever a schema file changes:
			      mvn generate-sources -Pregenerate-jaxb-sources
			    Or regenerate all JAXB modules at once:
			      ./misc/dev-support/scripts/regenerate-jaxb-sources.sh
			    After regeneration, commit the changed java-xjc files together with the XSD change.
			-->
			<id>regenerate-jaxb-sources</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.jvnet.jaxb2.maven2</groupId>
						<artifactId>maven-jaxb2-plugin</artifactId>
						<executions>
							<execution>
								<id>generate-de.metas.payment.sepa.jaxb.sct.schema-pain_008_003_02</id>
								<phase>generate-sources</phase>
								<goals>
									<goal>generate</goal>
								</goals>
								<configuration>
									<schemaDirectory>src/main/xsd</schemaDirectory>
									<generatePackage>de.metas.payment.sepa.jaxb.sct.pain_008_003_02</generatePackage>
									<generateDirectory>${project.basedir}/src/main/java-xjc</generateDirectory>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>
