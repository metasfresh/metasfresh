FROM node:18 AS build

RUN apt-get update && apt-get install -y locales && rm -rf /var/lib/apt/lists/* && localedef -i de_DE -c -f UTF-8 -A /usr/share/locale/locale.alias de_DE.UTF-8
ENV LANG=de_DE.UTF-8 LANGUAGE=de_DE.UTF-8 LC_MESSAGES=de_DE.UTF-8
ENV TZ=Europe/Berlin

WORKDIR /app

#
# Install required packages
# NOTE: copy the bare minimum config files at this point to favor caching
COPY e2e/frontend-webui/package.json* .
COPY e2e/frontend-webui/package-lock.json* .
RUN npm ci

# Install Playwright browsers with dependencies
RUN npx playwright install --with-deps chromium

#
# Copy the rest of our source files (i.e. the tests)
COPY e2e/frontend-webui/ .

#
# Start command — supports optional sharding via PLAYWRIGHT_SHARD env var
# Without PLAYWRIGHT_SHARD: runs all tests (current behavior)
# With PLAYWRIGHT_SHARD=1/3: runs `npx playwright test --shard=1/3`
CMD ["sh", "-c", "npx playwright test ${PLAYWRIGHT_SHARD:+--shard=$PLAYWRIGHT_SHARD}"]
