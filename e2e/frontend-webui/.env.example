# metasfresh Frontend Web UI - Playwright Test Configuration

# Frontend React Dev Server (where the web UI runs)
FRONTEND_BASE_URL=http://localhost:3000

# Testing API Base URL (where /frontendTesting endpoint is located)
# This runs on the app-server component (mobile UI + testing API)
TESTING_API_BASE_URL=http://localhost:8282/api/v2

# CI mode (enables retries)
# CI=true

# ===== Port Information =====
# Frontend (React dev server): localhost:3000 - Web UI
# Backend API (web frontend): localhost:8080/rest/api - API for web frontend
# App Server (mobile UI + testing): localhost:8282 - Mobile UI and /frontendTesting API
#
# Both port 8080 and 8282 must be running for the tests to work!
